{
  "name": "smart-error-copy",
  "displayName": "Smart Error Copy",
  "publisher": "surya-Dharmakrishnan",
  "description": "Copy full error context (message, file, line, stack trace) with one command.",
  "version": "0.0.1",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wolfofweb/smart-error-copy.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["error", "debug", "terminal", "logs"],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:smart-error-copy.copyError",
    "onCommand:smart-error-copy.copyFromTerminal"
  ],
  "contributes": {
    "commands": [
      {
        "command": "smart-error-copy.copyError",
        "title": "Copy Full Error Context"
      },
      {
        "command": "smart-error-copy.copyFromTerminal",
        "title": "Copy Error From Terminal"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "smart-error-copy.copyError",
          "group": "navigation"
        }
      ],
      "terminal/context": [
        {
          "command": "smart-error-copy.copyFromTerminal",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}